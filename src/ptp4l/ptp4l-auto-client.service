[Unit]
Description=ptp4l Client Service
After=network.target

[Service]
Type=exec
ExecStart=/usr/sbin/ptp4l -f /etc/linuxptp/ptp4l-auto-client.conf -i eth1 
CPUSchedulingPolicy=fifo
CPUSchedulingPriority=97
CPUAffinity=2
IOSchedulingClass=realtime
IOSchedulingPriority=0
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
